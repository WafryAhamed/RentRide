# ==============================
# RentRide User Service Config
# ==============================

# Server
APP_ENV=development
PORT=8080

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_NAME=rentride_users

# JWT
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRY=24h
