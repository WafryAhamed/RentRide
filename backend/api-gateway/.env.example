# ==============================
# RentRide API Gateway Config
# ==============================

APP_ENV=development
PORT=8000

# JWT Secret for gateway-level auth validation
JWT_ACCESS_SECRET=your-access-secret-change-in-production

# Service URLs
AUTH_SERVICE_URL=http://localhost:8081
USER_SERVICE_URL=http://localhost:8080
BOOKING_SERVICE_URL=http://localhost:8082
LOCATION_SERVICE_URL=http://localhost:8083
VEHICLE_SERVICE_URL=http://localhost:8084
PAYMENT_SERVICE_URL=http://localhost:8085
NOTIFICATION_SERVICE_URL=http://localhost:8086

# Rate Limiting
RATE_LIMIT_RPS=100
