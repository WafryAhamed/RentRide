# ==============================
# RentRide Auth Service Config
# ==============================

# Server
APP_ENV=development
PORT=8081

# PostgreSQL Database (Shared with User Service)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_NAME=rentride_users

# JWT Secrets
JWT_ACCESS_SECRET=your-access-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
